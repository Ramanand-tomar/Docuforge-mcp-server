# DocuForge MCP Configuration

# Storage: "memory" or "sqlite"
STORAGE_TYPE=memory

# SQLite database path (when STORAGE_TYPE=sqlite)
SQLITE_PATH=./data/docuforge.db

# PDF output directory
PDF_OUTPUT_DIR=./output

# REST API port
PORT=3000

# AI Integration
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Auth (Phase 7)
AUTH_ENABLED=false
JWT_SECRET=change-me-in-production
