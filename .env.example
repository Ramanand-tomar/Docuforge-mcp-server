# DocuForge MCP Configuration

# Storage: "memory" or "sqlite" (sqlite is recommended for production)
STORAGE_TYPE=sqlite

# SQLite database path (when STORAGE_TYPE=sqlite)
SQLITE_PATH=./data/docuforge.db

# PDF output directory
PDF_OUTPUT_DIR=./output

# REST API port
PORT=3000

# MCP API Key (required for production POST /mcp endpoint)
MCP_API_KEY=your-mcp-api-key

# AI Integration
GEMINI_API_KEY=

# Cloudinary Integration (for PDF storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Auth (Phase 7)
AUTH_ENABLED=false
# WARNING: MUST be changed from default in production!
JWT_SECRET=change-me-in-production
